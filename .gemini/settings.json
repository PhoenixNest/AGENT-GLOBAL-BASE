{
  "hooksConfig": {
    "enabled": false,
    "notifications": true
  },
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "context_engineering_context_assembler",
            "type": "command",
            "command": "python .gemini/hooks/context_engineering_context_assembler.py",
            "timeout": 5000
          },
          {
            "name": "multi_agent_engineering_handoff_packet",
            "type": "command",
            "command": "python .gemini/hooks/multi_agent_engineering_handoff_packet.py",
            "timeout": 5000
          },
          {
            "name": "multi_agent_engineering_swarm_orchestrator",
            "type": "command",
            "command": "python .gemini/hooks/multi_agent_engineering_swarm_orchestrator.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "context_engineering_context_compressor",
            "type": "command",
            "command": "python .gemini/hooks/context_engineering_context_compressor.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "context_engineering_memory_store",
            "type": "command",
            "command": "python .gemini/hooks/context_engineering_memory_store.py",
            "timeout": 5000
          },
          {
            "name": "harness_engineering_context_monitor",
            "type": "command",
            "command": "python .gemini/hooks/harness_engineering_context_monitor.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "harness_engineering_error_boundary",
            "type": "command",
            "command": "python .gemini/hooks/harness_engineering_error_boundary.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeToolSelection": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "harness_engineering_tool_registry",
            "type": "command",
            "command": "python .gemini/hooks/harness_engineering_tool_registry.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "multi_agent_engineering_git_worktree_manager",
            "type": "command",
            "command": "python .gemini/hooks/multi_agent_engineering_git_worktree_manager.py",
            "timeout": 5000
          },
          {
            "name": "retrieval_augmented_generation_initialize",
            "type": "command",
            "command": "python .gemini/hooks/retrieval_augmented_generation_initialize.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
