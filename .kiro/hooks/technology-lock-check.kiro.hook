{
  "name": "Technology Decision Lock",
  "version": "1.0.0",
  "description": "Prevent technology changes after Stage 3 approval. Verify that technology decisions (ADRs, TSD) are not being modified after Stage 3 user approval.",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Review the file that was just modified. If it's an ADR or TSD file in a project that has passed Stage 3 approval, this is a violation of AGENTS.md § 9 Rule 5. Technology decisions lock at Stage 3 and cannot be changed without full Stage 3 re-entry. Flag this as a P0 defect and recommend creating a new ADR instead."
  },
  "enabled": true,
  "workspaceFolderName": "agent-global-base",
  "shortName": "technology-lock-check"
}
