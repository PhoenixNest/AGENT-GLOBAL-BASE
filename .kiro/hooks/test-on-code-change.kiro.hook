{
  "name": "Run Tests on Code Change",
  "version": "1.0.0",
  "description": "Run relevant test suite after code changes to catch regressions early",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.py",
      "*.ts",
      "*.tsx",
      "*.kt",
      "*.swift",
      "*.js",
      "*.jsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A code file was just edited. If this is part of an active development task and tests exist for this module, run the relevant test suite to catch regressions early. Use appropriate test commands based on the file type (pytest for Python, npm test for JS/TS, etc.). Skip if no tests are configured or if the user explicitly requested no testing."
  },
  "enabled": true,
  "workspaceFolderName": "agent-global-base",
  "shortName": "test-on-code-change"
}
