{
  "name": "Pipeline Stage Gate",
  "version": "1.0.0",
  "description": "Enforce pipeline stage gates before task execution. Verify the task respects the current pipeline stage gate and check if user approval is required before proceeding.",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before starting this task, verify it respects the current pipeline stage gate. Check if user approval is required before proceeding to the next stage. Review AGENTS.md § 4.4 for company pipeline stage gates (13 stages) or § 5.3 for studio pipeline stage gates (11 stages). Confirm the current stage and whether this task requires user approval (✅) before execution."
  },
  "enabled": true,
  "workspaceFolderName": "agent-global-base",
  "shortName": "pipeline-stage-gate"
}
