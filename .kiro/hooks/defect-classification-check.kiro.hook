{
  "name": "Defect Severity Check",
  "version": "1.0.0",
  "description": "Verify P0/P1 defects are not downgraded. Ensure defect severity classifications remain accurate and are not changed to bypass stage gates.",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Review any defect classifications in the modified files. Per AGENTS.md § 9 Rule 6, P0/P1 defect classifications are non-overridable. P0 = crash/data loss/security breach. P1 = core feature broken. Verify no P0/P1 defects have been downgraded to P2/P3 to bypass Stage 6 or Stage 8 reviews."
  },
  "enabled": true,
  "workspaceFolderName": "agent-global-base",
  "shortName": "defect-classification-check"
}
