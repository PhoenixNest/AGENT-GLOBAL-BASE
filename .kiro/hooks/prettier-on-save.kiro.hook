{
  "name": "Prettier Auto-Format",
  "version": "1.0.0",
  "description": "Auto-format files on save per AGENTS.md § 8.7",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.md",
      "*.json",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run prettier --write on the file that was just edited to ensure consistent formatting per workspace conventions."
  },
  "enabled": true,
  "workspaceFolderName": "agent-global-base",
  "shortName": "prettier-on-save"
}
