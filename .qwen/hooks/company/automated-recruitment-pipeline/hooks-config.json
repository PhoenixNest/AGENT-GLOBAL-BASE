            "description": "Validates 60th percentile auto-reject, assessment battery assignment",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "interview-complete|assessment-scoring",
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/company/automated-recruitment-pipeline/scripts/stage-4-validate-interview-scores.py",
