{
  "_comment": "Recruitment Pipeline Hooks — Validator Model (v2.0)",
  "_updated": "2026-04-13",
  "_total": 23,
  "_model": "read-validate-audit-signal (hooks NEVER produce data artifacts)",
  "hooks": {
    "PostToolUseFailure": [
      {
        "matcher": "assessment|background-check|offer-generation|scoring",
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/company/automated-recruitment-pipeline/scripts/any-stage-escalate-r0-defect.py",
            "name": "r0-escalation",
            "description": "Classifies R0-R3 defects, pauses pipeline for R0/R1, escalates to CHRO",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "stage-complete|scoring|auto-reject|offer-generation|background-clearance|plan-consolidation|department-plan",
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/company/automated-recruitment-pipeline/scripts/any-stage-append-audit-log.py",
            "name": "entity-audit-append",
            "description": "SHA-256 chained audit trail appended to entity-specific audit log",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "offer-generation",
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/company/automated-recruitment-pipeline/scripts/stage-7-validate-offer-generation.py",
            "name": "stage-7-offer-validation",
            "description": "Validates compensation bands, offer completeness, multi-candidate handling",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "screening-complete",
        "hooks": [
          {
            "type": "command",
