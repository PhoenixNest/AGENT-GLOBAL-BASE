# RAG System Environment Variables
# Copy this file to .env and update with your actual values

# ============================================================================
# LM Studio Configuration
# ============================================================================
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=Qwen3.6-35B-A3B-Q4_K_M
LM_STUDIO_CONTEXT_LENGTH=16384
LM_STUDIO_MAX_TOKENS=4096
LM_STUDIO_TEMPERATURE=0.2

# ============================================================================
# Qdrant Vector Database Configuration
# ============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=coding_knowledge_base
QDRANT_API_KEY=

# ============================================================================
# Redis Cache Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# GPU Configuration
# ============================================================================
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# ============================================================================
# Thermal Management
# ============================================================================
THERMAL_WARNING_THRESHOLD=80
THERMAL_CRITICAL_THRESHOLD=85
THERMAL_CHECK_INTERVAL=30

# ============================================================================
# Performance Tuning
# ============================================================================
MAX_CONCURRENT_REQUESTS=3
REQUEST_TIMEOUT=180
EMBEDDING_BATCH_SIZE=32
RERANKING_BATCH_SIZE=8

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_PATH=./logs
LOG_FORMAT=json

# ============================================================================
# Security Configuration
# ============================================================================
ENABLE_ACCESS_CONTROL=false
ENABLE_PII_MASKING=true
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_PATH=./logs/audit

# ============================================================================
# Monitoring Configuration
# ============================================================================
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
