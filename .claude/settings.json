{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultShell": "powershell",
  "permissions": {
    "allow": [
      "PowerShell(python *)",
      "PowerShell(git *)",
      "PowerShell(prettier *)",
      "PowerShell(ruff *)",
      "PowerShell(pytest *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Get-Content *)",
      "mcp__workspace-knowledge__search_docs",
      "mcp__workspace-knowledge__retrieve_context",
      "mcp__workspace-knowledge__list_indexed_files",
      "mcp__workspace-knowledge__rebuild_index",
      "mcp__workspace-knowledge__summarize_context",
      "mcp__workspace-knowledge__check_adr_precedent",
      "mcp__workspace-knowledge__validate_pipeline_document",
      "mcp__git-worktree-manager__create_worktree",
      "mcp__git-worktree-manager__remove_worktree",
      "mcp__git-worktree-manager__list_worktrees",
      "mcp__git-worktree-manager__merge_branch",
      "mcp__git-worktree-manager__get_worktree_status",
      "mcp__git-worktree-manager__check_merge_conflicts",
      "mcp__git-worktree-manager__delete_branch"
    ],
    "deny": ["Read(./GEMINI.md)", "Read(./.gemini/**)"]
  },
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/prompt-quality-gate.ps1"]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/prompt-optimizer.ps1"]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/pipeline-context-injector.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/context-budget-alert.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/retrieval-augmented-generation-freshness-flag.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/harness-rate-limiter-turn-reset.ps1"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", ".claude/hooks/prompt-write-guard.ps1"]
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/harness-tool-rate-limiter.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/multi-agent-branch-naming-guard.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/multi-agent-commit-format-guard.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/system-powershell-syntax-guard.ps1"
            ]
          },
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/git-line-encoding-validator.ps1"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:/PROGRA~1/PowerShell/7/pwsh.exe",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/harness-error-boundary-monitor.ps1"
            ]
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python -u C:/Users/ASUS/.claude/statusline.py"
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "python -u C:/Users/ASUS/.claude/statusline.py"
  },
  "worktree": {
    "bgIsolation": "none"
  },
  "enabledMcpjsonServers": ["workspace-knowledge", "git-worktree-manager"]
}
