{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/prompt-quality-gate.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/prompt-optimizer.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/pipeline-context-injector.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/context-budget-alert.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/retrieval-augmented-generation-freshness-flag.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/harness-rate-limiter-turn-reset.ps1\"}else{exit 0}"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/prompt-gate-enforcer.ps1\"}else{exit 0}"]
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/prompt-write-guard.ps1\"}else{exit 0}"]
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/harness-tool-rate-limiter.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/multi-agent-branch-naming-guard.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/multi-agent-commit-format-guard.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/system-shell-syntax-guard.ps1\"}else{exit 0}"]
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/git-line-encoding-validator.ps1\"}else{exit 0}"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/prompt-gate-clear.ps1\"}else{exit 0}"]
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/rag-index-sync.ps1\"}else{exit 0}"]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-ExecutionPolicy", "Bypass", "-Command", "$r=git rev-parse --show-toplevel 2>$null; if($LASTEXITCODE -eq 0){& \"$r/.claude/hooks/harness-error-boundary-monitor.ps1\"}else{exit 0}"]
          }
        ]
      }
    ]
  },
  "worktree": {
    "bgIsolation": "none"
  },
  "enabledMcpjsonServers": ["workspace-knowledge"],
  "permissions": {
    "allow": [
      "mcp__workspace-knowledge__search_docs",
      "mcp__workspace-knowledge__retrieve_context",
      "mcp__workspace-knowledge__list_indexed_files",
      "mcp__workspace-knowledge__rebuild_index",
      "mcp__workspace-knowledge__upsert_document",
      "mcp__workspace-knowledge__summarize_context",
      "mcp__workspace-knowledge__check_adr_precedent",
      "mcp__workspace-knowledge__validate_pipeline_document",
      "mcp__workspace-knowledge__find_related_documents",
      "mcp__workspace-knowledge__list_research_by_topic",
      "mcp__workspace-knowledge__agent_knowledge_brief"
    ]
  },
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
